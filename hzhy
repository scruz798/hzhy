    btn.innerHTML = '<span class="loading-spinner"></span> Menghantar...';
    btn.disabled = true;

    if (USE_DEMO_DATA || !GOOGLE_SCRIPT_URL.includes('AKfycbz')) {
        setTimeout(() => {
            const newBooking = {
                Timestamp: new Date().toLocaleString(),
                ...formData,
                Status: 'Pending'
            };
            currentBookingsData.unshift(newBooking);
            renderAdminTable();
            
            btn.innerHTML = '<span>Hantar Permintaan Tempahan</span>';
            btn.disabled = false;
            status.className = 'form-status success';
            status.textContent = '✓ Permintaan tempahan berjaya dihantar! Kami akan menghubungi anda dalam 24 jam.';
            form.reset();
            showToast('Tempahan berjaya dihantar!', 'success');
            
            setTimeout(() => { status.className = 'form-status'; }, 5000);
        }, 1500);
        return;
    }

    try {
        await fetch(GOOGLE_SCRIPT_URL, {
            method: 'POST',
            mode: 'no-cors',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(formData)
        });

        btn.innerHTML = '<span>Hantar Permintaan Tempahan</span>';
        btn.disabled = false;
        status.className = 'form-status success';
        status.textContent = '✓ Permintaan tempahan berjaya dihantar! Kami akan menghubungi anda dalam 24 jam.';
        form.reset();
        showToast('Tempahan dihantar ke Google Sheets!', 'success');
        
        setTimeout(() => { status.className = 'form-status'; }, 5000);
    } catch (err) {
        btn.innerHTML = '<span>Hantar Permintaan Tempahan</span>';
        btn.disabled = false;
        status.className = 'form-status error';
        status.textContent = '✗ Ralat menghantar. Sila cuba lagi atau hubungi kami secara langsung.';
        showToast('Gagal menghantar. Sila cuba lagi.', 'error');
    }
}

// ==========================================
// EKSPORT CSV
// ==========================================
function exportCSV() {
    let data, filename;
    switch (currentAdminTab) {
        case 'bookings': data = currentBookingsData; filename = 'tempahan'; break;
        case 'menu': data = currentMenuData; filename = 'menu'; break;
        case 'testimonials': data = currentTestimonialsData; filename = 'ulasan'; break;
    }

    if (!data.length) { showToast('Tiada data untuk dieksport', 'error'); return; }

    const headers = Object.keys(data[0]);
    const csv = [
        headers.join(','),
        ...data.map(row => headers.map(h => `"${(row[h] || '').toString().replace(/"/g, '""')}"`).join(','))
    ].join('\n');

    const blob = new Blob([csv], { type: 'text/csv' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `hzhy-legacy-${filename}-${new Date().toISOString().split('T')[0]}.csv`;
    a.click();
    URL.revokeObjectURL(url);
    showToast(`${filename} dieksport sebagai CSV!`, 'success');
}

// ==========================================
// UTILITI UI
// ==========================================
function showToast(message, type = 'success') {
    const toast = document.getElementById('toast');
    toast.className = `toast ${type} show`;
    toast.innerHTML = `${type === 'success' ? '✓' : '✗'} ${message}`;
    setTimeout(() => { toast.classList.remove('show'); }, 4000);
}

function closeModal(e) {
    if (e.target === document.getElementById('modalOverlay')) {
        document.getElementById('modalOverlay').classList.remove('active');
    }
}

function toggleNav() {
    document.getElementById('navLinks').classList.toggle('open');
}

window.addEventListener('scroll', () => {
    const navbar = document.getElementById('navbar');
    navbar.classList.toggle('scrolled', window.scrollY > 50);
});

const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
        if (entry.isIntersecting) {
            entry.target.classList.add('visible');
        }
    });
}, { threshold: 0.1 });

document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));

function animateCounters() {
    document.querySelectorAll('.stat-number[data-count]').forEach(el => {
        const target = parseInt(el.dataset.count);
        const duration = 2000;
        const step = target / (duration / 16);
        let current = 0;
        const timer = setInterval(() => {
            current += step;
            if (current >= target) {
                current = target;
                clearInterval(timer);
            }
            el.textContent = Math.round(current).toLocaleString() + (target === 98 ? '%' : '+');
        }, 16);
    });
}

const statsObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
        if (entry.isIntersecting) {
            animateCounters();
            statsObserver.disconnect();
        }
    });
}, { threshold: 0.5 });

document.querySelector('.stats-bar') && statsObserver.observe(document.querySelector('.stats-bar'));

document.addEventListener('DOMContentLoaded', () => {
    const dateInput = document.querySelector('input[name="eventDate"]');
    if (dateInput) {
        const today = new Date().toISOString().split('T')[0];
        dateInput.setAttribute('min', today);
    }
    loadSheetData();
});

document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function(e) {
        e.preventDefault();
        const target = document.querySelector(this.getAttribute('href'));
        if (target) {
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            document.getElementById('navLinks').classList.remove('open');
        }
    });
});
</script>
