function switchAdminTab(tab) {
    currentAdminTab = tab;
    document.querySelectorAll('.admin-tab').forEach(t => t.classList.remove('active'));
    event.target.classList.add('active');
    renderAdminTable();
}

function renderAdminTable() {
    const thead = document.getElementById('adminTableHead');
    const tbody = document.getElementById('adminTableBody');
    let data, columns;

    switch (currentAdminTab) {
        case 'bookings':
            data = currentBookingsData;
            columns = ['Timestamp', 'FullName', 'Email', 'EventDate', 'EventType', 'Guests', 'Package', 'Status'];
            break;
        case 'menu':
            data = currentMenuData;
            columns = ['Name', 'Category', 'Price', 'Serves', 'Badge'];
            break;
        case 'testimonials':
            data = currentTestimonialsData;
            columns = ['ClientName', 'Event', 'Rating', 'Text'];
            break;
    }

    thead.innerHTML = `<tr>${columns.map(c => `<th>${c}</th>`).join('')}<th>Tindakan</th></tr>`;
    
    tbody.innerHTML = data.map((row, idx) => {
        const cells = columns.map(col => {
            let val = row[col] || '';
            if (col === 'Status') {
                const cls = val === 'Confirmed' ? 'status-confirmed' : val === 'Pending' ? 'status-pending' : 'status-cancelled';
                return `<td><span class="status-badge ${cls}">${val}</span></td>`;
            }
            if (col === 'Rating') {
                return `<td style="color:var(--gold)">${'★'.repeat(val)}${'☆'.repeat(5 - val)}</td>`;
            }
            if (col === 'Text') {
                return `<td style="max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${val}</td>`;
            }
            return `<td>${val}</td>`;
        }).join('');
        
        return `<tr>${cells}<td><div class="admin-actions">
            <button class="btn-view" onclick="viewRecord(${idx})">Lihat</button>
            <button class="btn-edit" onclick="editRecord(${idx})">Sunting</button>
            <button class="btn-delete" onclick="deleteRecord(${idx})">Padam</button>
        </div></td></tr>`;
    }).join('');
}

function viewRecord(idx) {
    let record;
    switch (currentAdminTab) {
        case 'bookings': record = currentBookingsData[idx]; break;
        case 'menu': record = currentMenuData[idx]; break;
        case 'testimonials': record = currentTestimonialsData[idx]; break;
    }
    
    const content = Object.entries(record).map(([key, val]) => `
        <div style="margin-bottom:12px">
            <div style="font-size:11px;color:var(--text-light);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:2px">${key}</div>
            <div style="font-size:14px;font-weight:500">${val}</div>
        </div>
    `).join('');
    
    document.getElementById('modalContent').innerHTML = `<h3 style="margin-bottom:20px;font-size:22px;color:var(--purple-dark)">Butiran Rekod</h3>${content}`;
    document.getElementById('modalOverlay').classList.add('active');
}

function editRecord(idx) {
    showToast('Fungsi sunting memerlukan akses tulis Google Sheets melalui Apps Script', 'success');
}

function deleteRecord(idx) {
    if (confirm('Adakah anda pasti mahu memadam rekod ini?')) {
        switch (currentAdminTab) {
            case 'bookings': currentBookingsData.splice(idx, 1); break;
            case 'menu': currentMenuData.splice(idx, 1); break;
            case 'testimonials': currentTestimonialsData.splice(idx, 1); break;
        }
        renderAdminTable();
        showToast('Rekod dipadam (lokal sahaja — kemas kini Google Sheet untuk simpan)', 'success');
    }
}

