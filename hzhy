function renderMenu(items, filter = 'all') {
    const grid = document.getElementById('menuGrid');
    const filtered = filter === 'all' ? items : items.filter(i => i.Category === filter);
    
    grid.innerHTML = filtered.map(item => `
        <div class="menu-item" data-category="${item.Category}">
            <div class="menu-item-img" style="background-image:url('${item.ImageURL || 'https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=400'}')">
                ${item.Badge ? `<span class="menu-item-badge">${item.Badge}</span>` : ''}
            </div>
            <div class="menu-item-body">
                <h4>${item.Name}</h4>
                <p>${item.Description}</p>
                <div class="menu-item-footer">
                    <span class="menu-price">${item.Price}</span>
                    <span class="menu-serves">${item.Serves}</span>
                </div>
            </div>
        </div>
    `).join('');
}

function filterMenu(category) {
